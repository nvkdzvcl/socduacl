# Environment Variables

# PostgreSQL
POSTGRES_USER=socduacl
POSTGRES_PASSWORD=socduacl_secret
POSTGRES_DB=socduacl_db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_DEFAULT_USER=socduacl
RABBITMQ_DEFAULT_PASS=socduacl_secret
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# MinIO
MINIO_ROOT_USER=socduacl
MINIO_ROOT_PASSWORD=socduacl_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend
JWT_SECRET=super_secret_jwt_key_that_must_be_at_least_256_bits_long
JWT_EXPIRATION_MS=86400000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
